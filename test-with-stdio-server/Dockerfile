ARG STDIO_SERVER_IMAGE
FROM ${STDIO_SERVER_IMAGE} AS server

# Main test container
FROM python:3.11-slim
WORKDIR /app

# Copy server files from the STDIO server image
COPY --from=server / /server-root/

# Copy plugin source and config
COPY pyproject.toml README.md /app/
COPY src /app/src

# Install plugin and pytest
RUN python -m pip install --upgrade pip setuptools wheel && \
    pip install -e . && \
    pip install pytest

# Install server dependencies from its requirements.txt if it exists
RUN if [ -f /server-root/app/requirements.txt ]; then \
        pip install -r /server-root/app/requirements.txt; \
    elif [ -f /server-root/requirements.txt ]; then \
        pip install -r /server-root/requirements.txt; \
    fi

# Create wrapper script to run the server
RUN echo '#!/bin/bash\n\
cd /server-root/app 2>/dev/null || cd /server-root\n\
if [ -f server.py ]; then\n\
    exec python server.py "$@"\n\
elif [ -f main.py ]; then\n\
    exec python main.py "$@"\n\
elif [ -f app.py ]; then\n\
    exec python app.py "$@"\n\
else\n\
    echo "Error: Could not find server entry point (server.py, main.py, or app.py)" >&2\n\
    exit 1\n\
fi' > /usr/local/bin/run-server && \
    chmod +x /usr/local/bin/run-server

# Create empty test directory
RUN mkdir -p /app/test_stdio && \
    echo "# Placeholder - tests auto-generated by --mcp-tools" > /app/test_stdio/__init__.py

WORKDIR /app/test_stdio
CMD ["pytest"]
