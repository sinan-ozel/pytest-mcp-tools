FROM python:3.11-slim
WORKDIR /app

# Copy only what's needed to install the plugin (exclude tests)
COPY ../src /app/src
COPY ../pyproject.toml /app/pyproject.toml
COPY ../README.md /app/README.md

RUN apt-get update && apt-get install -y --no-install-recommends build-essential gcc libffi-dev && rm -rf /var/lib/apt/lists/*
RUN python -m pip install --upgrade pip setuptools wheel
RUN pip install -e .
RUN pip install pytest

# Create empty test directory so pytest has something to collect
RUN mkdir -p /app/test_dockerhub && echo "# Placeholder - tests auto-generated by --mcp-tools" > /app/test_dockerhub/__init__.py

WORKDIR /app/test_dockerhub
CMD ["pytest"]
